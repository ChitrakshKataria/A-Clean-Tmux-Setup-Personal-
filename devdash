#!/usr/bin/env bash
set -Eeuo pipefail

SESSION="${SESSION:-dev}"
WINDOW="${WINDOW:-main}"
PROJECT="${1:-$PWD}"
PROJECT="$(cd "$PROJECT" && pwd)"

command -v tmux >/dev/null 2>&1 || {
  echo "tmux is not installed."
  exit 1
}

BASE_SESSION="$SESSION"
session_suffix=2
while tmux has-session -t "$SESSION" 2>/dev/null; do
  SESSION="${BASE_SESSION}-${session_suffix}"
  session_suffix=$((session_suffix + 1))
done

attach_session() {
  if [[ -n "${TMUX:-}" ]]; then
    tmux switch-client -t "$SESSION"
  else
    tmux attach-session -t "$SESSION"
  fi
}

escape_single_quotes() {
  printf "%s" "$1" | sed "s/'/'\\\\''/g"
}

pane_cmd() {
  local body
  body="$(escape_single_quotes "$1")"
  printf "bash -lc '%s; printf \"\\n\\n[exited] shell ready\\n\"; exec bash -l'" "$body"
}

# ---------- Pane commands ----------
GIT_RUN="${GIT_RUN:-if command -v lazygit >/dev/null 2>&1; then lazygit; else git status; fi}"

FILES_RUN="${FILES_RUN:-if command -v yazi >/dev/null 2>&1; then yazi; elif command -v nvim >/dev/null 2>&1; then nvim .; else ls -la; fi}"

CODEX_RUN="${CODEX_RUN:-if command -v codex >/dev/null 2>&1; then codex; else echo \"Codex not found.\"; fi}"

CLAUDE_2_RUN="${CLAUDE_2_RUN:-if command -v claude >/dev/null 2>&1; then claude; else echo \"Claude Code not found.\"; fi}"

SIDE_RUN="${SIDE_RUN:-bash -l}"

if [[ -n "${DEV_RUN:-}" ]]; then
  DEV_COMMAND="$DEV_RUN"
elif [[ -f "$PROJECT/package.json" ]]; then
  if [[ -f "$PROJECT/bun.lockb" || -f "$PROJECT/bun.lock" ]]; then
    DEV_COMMAND="bun run dev"
  elif [[ -f "$PROJECT/pnpm-lock.yaml" ]]; then
    DEV_COMMAND="pnpm dev"
  elif [[ -f "$PROJECT/yarn.lock" ]]; then
    DEV_COMMAND="yarn dev"
  else
    DEV_COMMAND="npm run dev"
  fi
else
  DEV_COMMAND="echo \"No package.json found. Dev pane ready.\""
fi

# ---------- Create layout ----------
git_pane="$(
  tmux new-session -d \
    -s "$SESSION" \
    -n "$WINDOW" \
    -c "$PROJECT" \
    -P -F "#{pane_id}" \
    "$(pane_cmd "$GIT_RUN")"
)"

claude_top_pane="$(
  tmux split-window -h \
    -t "$git_pane" \
    -c "$PROJECT" \
    -P -F "#{pane_id}" \
    "$(pane_cmd "$CODEX_RUN")"
)"

side_pane="$(
  tmux split-window -h \
    -t "$claude_top_pane" \
    -c "$PROJECT" \
    -P -F "#{pane_id}" \
    "$(pane_cmd "$SIDE_RUN")"
)"

files_pane="$(
  tmux split-window -v \
    -t "$git_pane" \
    -c "$PROJECT" \
    -P -F "#{pane_id}" \
    "$(pane_cmd "$FILES_RUN")"
)"

claude_bottom_pane="$(
  tmux split-window -v \
    -t "$claude_top_pane" \
    -c "$PROJECT" \
    -P -F "#{pane_id}" \
    "$(pane_cmd "$CLAUDE_2_RUN")"
)"

dev_pane="$(
  tmux split-window -v \
    -t "$side_pane" \
    -c "$PROJECT" \
    -P -F "#{pane_id}" \
    "$(pane_cmd "$DEV_COMMAND")"
)"

# ---------- Resize layout ----------
cols="$(tput cols 2>/dev/null || echo 160)"
lines="$(tput lines 2>/dev/null || echo 45)"

if ! [[ "$cols" =~ ^[0-9]+$ ]]; then
  cols=160
fi

if ! [[ "$lines" =~ ^[0-9]+$ ]]; then
  lines=45
fi

left_w=$(( cols * 24 / 100 ))
right_w=$(( cols * 25 / 100 ))

left_top_h=$(( lines * 55 / 100 ))
right_top_h=$(( lines * 58 / 100 ))
middle_top_h=$(( lines * 50 / 100 ))

(( left_w < 26 )) && left_w=26
(( right_w < 28 )) && right_w=28
(( left_top_h < 8 )) && left_top_h=8
(( right_top_h < 8 )) && right_top_h=8
(( middle_top_h < 8 )) && middle_top_h=8

tmux resize-pane -t "$git_pane" -x "$left_w" || true
tmux resize-pane -t "$side_pane" -x "$right_w" || true

tmux resize-pane -t "$git_pane" -y "$left_top_h" || true
tmux resize-pane -t "$side_pane" -y "$right_top_h" || true
tmux resize-pane -t "$claude_top_pane" -y "$middle_top_h" || true

# ---------- Styling ----------
tmux set-option -t "$SESSION" status off
tmux set-option -t "$SESSION" mouse on

# Full grey inactive borders, bright green selected border
tmux set-window-option -t "$SESSION:$WINDOW" pane-border-status top
tmux set-window-option -t "$SESSION:$WINDOW" pane-border-style "fg=colour248"
tmux set-window-option -t "$SESSION:$WINDOW" pane-active-border-style "fg=colour46,bold"

# Pane title line changes color depending on selected pane
tmux set-window-option -t "$SESSION:$WINDOW" pane-border-format '#[fg=#{?pane_active,colour46,colour248},bold] #T #[fg=#{?pane_active,colour46,colour248}]━━━━━━━━━━━━━━━━ '

# Thicker borders if your tmux supports it
tmux set-window-option -t "$SESSION:$WINDOW" pane-border-lines heavy 2>/dev/null || true

# Copy/scroll mode
tmux set-window-option -t "$SESSION:$WINDOW" mode-style "fg=colour255,bg=colour24"

# ---------- Pane names ----------
tmux select-pane -t "$git_pane" -T "git"
tmux select-pane -t "$files_pane" -T "files"
tmux select-pane -t "$claude_top_pane" -T "codex"
tmux select-pane -t "$claude_bottom_pane" -T "claude helper"
tmux select-pane -t "$side_pane" -T "shell"
tmux select-pane -t "$dev_pane" -T "next-server"

tmux select-pane -t "$claude_top_pane"

attach_session
